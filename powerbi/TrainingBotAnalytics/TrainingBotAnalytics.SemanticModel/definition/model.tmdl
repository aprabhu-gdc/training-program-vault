model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["SharePointSiteUrl","QueryEvents","Feedback","_Measures"]

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_ProTooling = ["DevMode"]

ref table QueryEvents
ref table Feedback
ref table DimUser
ref table DimDate
ref table _Measures

ref cultureInfo en-US

