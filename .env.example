# Microsoft Bot registration settings.
# These names match the standard Bot Framework environment variable convention.
MicrosoftAppId=your-bot-app-id
MicrosoftAppPassword=your-bot-app-password

# Local web server port.
PORT=3978

# Import path for your existing wiki query function.
# Expected format: package.module:function_name
# Default: local RAG backend for wiki/
WIKI_QUERY_CALLABLE=rag_backend.query:query_vault

# Optional alternative to WIKI_QUERY_CALLABLE:
# point the bot at an already-running internal HTTP endpoint that can query the
# training vault on a machine with Egnyte access.
# Example: http://wiki-api.internal:8000/query
WIKI_QUERY_HTTP_URL=

# Optional timeout for the existing wiki query pipeline.
WIKI_QUERY_TIMEOUT_SECONDS=45

# Optional vault root override. Defaults to the repository root.
VAULT_ROOT=

# Local vector store settings. Defaults point at local app data so the embedded
# database does not live on the Egnyte UNC path.
LOCAL_DATA_ROOT=
VECTOR_DB_PATH=
VECTOR_TABLE_NAME=training-vault-wiki
VECTOR_MANIFEST_PATH=

# Retrieval controls.
RAG_TOP_K=6
RAG_INDEX_SUMMARY_CHARS=5000

# OpenAI settings. Use either standard OpenAI or Azure OpenAI below.
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=
OPENAI_VISION_MODEL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Azure OpenAI alternative.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_VISION_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# Egnyte sync settings.
EGNYTE_DOMAIN=your-subdomain.egnyte.com
EGNYTE_API_TOKEN=your-egnyte-api-token
EGNYTE_SYNC_ROOT=Shared/East/Team CRD
EGNYTE_TRAINING_FOLDER_NAME=Training Program CRD
EGNYTE_REQUEST_TIMEOUT_SECONDS=60
EGNYTE_SYNC_STATE_PATH=

# Auto-ingest prompt sizing.
AUTO_INGEST_MAX_SOURCE_CHARS=18000

# Optional logging verbosity.
LOG_LEVEL=INFO
