# Microsoft Bot registration settings.
# These names match the standard Bot Framework environment variable convention.
MicrosoftAppId=your-bot-app-id
MicrosoftAppPassword=your-bot-app-password

# Teams bot web server port.
PORT=3978

# Standalone service ports for local multi-process runs.
QUERY_API_PORT=8000
INGEST_API_PORT=8010

# Import path for your existing wiki query function.
# Expected format: package.module:function_name
# Default: local RAG backend for wiki/
WIKI_QUERY_CALLABLE=rag_backend.query:query_vault

# Optional alternative to WIKI_QUERY_CALLABLE:
# point the bot at the full HTTP query endpoint URL of an already-running query
# service on a machine with vault access.
# Example: http://wiki-api.internal:8000/query
WIKI_QUERY_HTTP_URL=

# Ingest admin API for manual sync requests from Teams.
# This should be the ingest API base URL, not the /admin/sync path.
# Example: http://ingest-api.internal:8010
INGEST_ADMIN_HTTP_URL=

# Optional timeout for the existing wiki query pipeline.
WIKI_QUERY_TIMEOUT_SECONDS=45

# Optional vault root override. Defaults to the repository root.
VAULT_ROOT=

# Local vector store and sync-state settings. Defaults point at local app data so
# embedded runtime state does not live in a synced SharePoint workspace.
LOCAL_DATA_ROOT=
VECTOR_DB_PATH=
VECTOR_TABLE_NAME=training-vault-wiki
VECTOR_MANIFEST_PATH=
SOURCE_SYNC_STATE_PATH=

# Retrieval controls.
RAG_TOP_K=6
RAG_INDEX_SUMMARY_CHARS=5000

# Generic LLM routing.
# The environment contract is provider-agnostic so chat, vision, and embeddings
# can be routed independently if needed.
LLM_PROVIDER=
LLM_CHAT_PROVIDER=
LLM_CHAT_MODEL=
LLM_VISION_PROVIDER=
LLM_VISION_MODEL=
LLM_EMBEDDING_PROVIDER=
LLM_EMBEDDING_MODEL=

# Provider credentials and endpoints.
# OpenAI-compatible.
LLM_OPENAI_API_KEY=
LLM_OPENAI_BASE_URL=

# Azure OpenAI (Microsoft AI Foundry project endpoints work here).
LLM_AZURE_OPENAI_ENDPOINT=
LLM_AZURE_OPENAI_API_KEY=
LLM_AZURE_OPENAI_API_VERSION=2024-02-01

# Notes:
# - Supported runtime providers (chat, vision, embedding): openai, azure-openai

# SharePoint source sync settings.
# Remote SharePoint Online is the production source of truth for raw/sources and wiki/.
# A local SharePoint-synced folder is optional for development only and is not a
# required production dependency.
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
# Optional when you prefer to configure the exact site ID directly.
SHAREPOINT_SITE_ID=
# Otherwise configure hostname + site path, for example:
# SHAREPOINT_SITE_HOSTNAME=graydazeb.sharepoint.com
# SHAREPOINT_SITE_PATH=/Training Program Vault
SHAREPOINT_SITE_HOSTNAME=
SHAREPOINT_SITE_PATH=
# Configure one of the document library list ID, drive ID, or drive name.
SHAREPOINT_LIST_ID=
SHAREPOINT_DRIVE_ID=
SHAREPOINT_DRIVE_NAME=Training Program Vault
SHAREPOINT_RAW_ROOT_PATH=raw/sources
SHAREPOINT_WIKI_ROOT_PATH=wiki
SHAREPOINT_REQUEST_TIMEOUT_SECONDS=60

# Public HTTPS URL Microsoft Graph will POST notifications to.
# Must be reachable from Graph (no localhost). Required for near-real-time sync.
SHAREPOINT_WEBHOOK_NOTIFICATION_URL=
# Shared secret echoed in every notification; rotate independently of app secrets.
SHAREPOINT_WEBHOOK_CLIENT_STATE=

# Auto-ingest prompt sizing.
AUTO_INGEST_MAX_SOURCE_CHARS=18000

# Optional logging verbosity.
LOG_LEVEL=INFO

# Azure Service Bus queueing for ingest jobs.
# Configure either a connection string or a namespace for DefaultAzureCredential.
SERVICE_BUS_CONNECTION_STRING=
SERVICE_BUS_NAMESPACE=
INGEST_QUEUE_NAME=training-vault-ingest
